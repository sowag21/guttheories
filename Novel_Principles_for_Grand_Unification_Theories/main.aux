\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces The "Mexican hat" potential $V(\mitphi )$ from Eq.~\eqref  {eq:Mexipot}. The system begins in a local unstable maximum (top red sphere), after which it rolls down (red arrow) into the continuous valley of degenerate global minima (bottom red sphere). This is a visual representation of SSB. The massless Goldstone bosons correspond to the rotational degree of freedom along the flat valley, while the massive Higgs boson corresponds to radial excitations up the sides of the potential.}}{28}{figure.caption.5}\protected@file@percent }
\newlabel{fig:mexihat}{{3.1}{28}{The "Mexican hat" potential $V(\phi )$ from Eq.~\eqref {eq:Mexipot}. The system begins in a local unstable maximum (top red sphere), after which it rolls down (red arrow) into the continuous valley of degenerate global minima (bottom red sphere). This is a visual representation of SSB. The massless Goldstone bosons correspond to the rotational degree of freedom along the flat valley, while the massive Higgs boson corresponds to radial excitations up the sides of the potential}{figure.caption.5}{}}
\newlabel{eq:Higgs1}{{3.26}{28}{The Higgs mechanism}{equation.3.26}{}}
\newlabel{eq:LHiggs}{{3.27}{28}{The Higgs mechanism}{equation.3.27}{}}
